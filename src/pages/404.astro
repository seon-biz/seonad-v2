---
import BaseLayout from '@layouts/BaseLayout.astro';
import ComingSoon from '@components/ComingSoon.astro';
import { brand } from '@config/campaign';
---

<BaseLayout
  title={`페이지를 찾을 수 없습니다 | ${brand.name}`}
  description="요청하신 페이지를 찾을 수 없습니다."
  noindex
  hideFloatingCTA
>
  <ComingSoon
    pageTitle="요청하신 페이지를 찾을 수 없습니다."
    description="주소가 바뀌었거나 아직 준비되지 않은 페이지일 수 있습니다. 메인으로 돌아가 다시 시도해 주세요."
  />
</BaseLayout>
