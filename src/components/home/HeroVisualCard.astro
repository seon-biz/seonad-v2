---
/*
 * HeroVisualCard — 메인 히어로 우측 스택 전용 카드 (02-main-page.md §2-3)
 *
 * 배경: navy-800 → navy-900 그라디언트 + gold 30% 1px 테두리 + 인셋 골드 글로우.
 * 장식: 네 모서리 L자 브래킷 + 은은한 골드 그리드 오버레이 (6% opacity).
 * 중앙: 카드별 라인아트 아이콘(play/monitor/book) + 라벨(스몰캡) + 캡션.
 *
 * 이 컴포넌트는 "의도된 와이어프레임"으로 읽히도록 설계되어 실제 썸네일 스크린샷이
 * 준비되기 전까지 히어로 시각 블록을 채운다. 추후 <img slot="media" /> 또는
 * 배경 이미지 치환만으로 실사 카드로 전환 가능.
 *
 *  - aspect 3:4 고정 (히어로 스택 리듬 유지)
 *  - 부모 wrapper 에서 rotate/translate 을 적용받음 (§2-3 카드 어긋난 배치)
 */

export type HeroCardIcon = 'play' | 'monitor' | 'book';

interface Props {
  label: string;
  caption?: string;
  icon: HeroCardIcon;
  class?: string;
}

const { label, caption, icon, class: className = '' } = Astro.props;
---

<div
  class:list={[
    'group relative aspect-[3/4] overflow-hidden rounded-2xl',
    'bg-gradient-to-br from-navy-800 to-navy-900',
    'border border-gold-500/30',
    'shadow-[inset_0_0_40px_rgba(212,165,77,0.08)]',
    className,
  ]}
  aria-hidden="true"
>
  {/* 은은한 골드 그리드 오버레이 — 6% opacity */}
  <div
    class="pointer-events-none absolute inset-0 text-gold-500 opacity-[0.06]"
    style="background-image: linear-gradient(currentColor 1px, transparent 1px), linear-gradient(to right, currentColor 1px, transparent 1px); background-size: 28px 28px;"
  ></div>

  {/* 상단에서 아래로 서서히 어두워지는 비네팅 — 중앙 내용 가독 */}
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-navy-950/50"
  ></div>

  {/* 네 모서리 L자 브래킷 — 설계 도면 느낌 */}
  <span class="pointer-events-none absolute left-4 top-4 h-5 w-5 border-l border-t border-gold-500/50"></span>
  <span class="pointer-events-none absolute right-4 top-4 h-5 w-5 border-r border-t border-gold-500/50"></span>
  <span class="pointer-events-none absolute bottom-4 left-4 h-5 w-5 border-b border-l border-gold-500/50"></span>
  <span class="pointer-events-none absolute bottom-4 right-4 h-5 w-5 border-b border-r border-gold-500/50"></span>

  {/* 중앙 컨텐츠 */}
  <div class="absolute inset-0 flex flex-col items-center justify-center gap-sp-3 px-sp-5 text-center">
    <svg
      class="h-12 w-12 text-gold-500/70"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      {
        icon === 'play' && (
          <>
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path
              d="m10.5 9 5 3-5 3V9z"
              fill="currentColor"
              fill-opacity="0.35"
            />
          </>
        )
      }
      {
        icon === 'monitor' && (
          <>
            <rect x="3" y="4" width="18" height="12" rx="2" />
            <path d="M7 8h4" />
            <path d="M8 20h8" />
            <path d="M12 16v4" />
          </>
        )
      }
      {
        icon === 'book' && (
          <>
            <path d="M5 4h9a4 4 0 0 1 4 4v12H9a4 4 0 0 1-4-4V4z" />
            <path d="M5 16a4 4 0 0 1 4-4h9" />
            <path d="M9 8h5" />
          </>
        )
      }
    </svg>
    <p class="text-[11px] font-semibold uppercase tracking-[0.3em] text-gold-400/90">
      {label}
    </p>
    {
      caption && (
        <p class="text-caption leading-tight text-white/70">{caption}</p>
      )
    }
  </div>
</div>
