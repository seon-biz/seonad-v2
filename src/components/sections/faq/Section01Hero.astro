---
/*
 * /faq Section 01 — Hero (06-faq.md §2)
 *
 * - navy-900, container-narrow, min-h 35vh (기능 페이지라 짧게)
 * - 브레드크럼 · h1 · 서브 · (하단 탭은 FaqTabs 컴포넌트가 별도 렌더)
 * - 숫자 "42"를 gold-400 으로 강조해 시각 흐름
 */
import { routes } from '@config/campaign';
---

<section class="bg-navy-900 text-on-dark">
  <div class="mx-auto w-full max-w-[var(--container-narrow)] px-sp-5 py-sp-16 lg:min-h-[35vh] lg:py-sp-20">
    <nav aria-label="브레드크럼" class="text-caption text-navy-400">
      <ol class="flex items-center gap-sp-2">
        <li>
          <a href={routes.home} class="hover:text-gold-300">세온애드</a>
        </li>
        <li aria-hidden="true">›</li>
        <li aria-current="page" class="text-on-dark-soft">FAQ</li>
      </ol>
    </nav>

    <h1 class="mt-sp-6 text-h1 font-bold leading-tight text-paper">
      결제 전에 확인할<br />
      <span class="text-gold-400">42가지</span> 질문.
    </h1>

    <p class="mt-sp-5 max-w-[60ch] text-lead text-gold-300">
      강의 구성, 모집, 결제, 환불, 애프터케어까지.<br />
      답이 찾기 쉽게 7개 카테고리로 정리했습니다.
    </p>
  </div>
</section>
