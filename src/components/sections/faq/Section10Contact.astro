---
/*
 * /faq Section 10 — 카테고리에 없는 질문 (06-faq.md §11)
 *
 * - navy-900 다크 배경, 중앙 정렬
 * - 이메일 + 카카오톡 채널 2열 연락처 블록
 * - 부가 문구: 법인명 · 대표 연락처 · 업무 시간
 */
import { brand, business } from '@config/campaign';
---

<section class="bg-navy-900 text-on-dark">
  <div class="container-max section-y">
    <div class="mx-auto max-w-[760px] text-center">
      <h2 class="text-h2 font-bold text-paper">여기 없는 질문이 있다면.</h2>
      <p class="mt-sp-4 text-lead text-gold-300">
        카카오톡 채널 또는 이메일로 문의해주세요.<br />
        24시간 이내 답변드립니다.
      </p>

      <ul class="mx-auto mt-sp-10 grid max-w-[600px] grid-cols-1 gap-sp-4 sm:grid-cols-2">
        <li>
          <a
            href={`mailto:${brand.email}`}
            class="flex min-h-[88px] w-full items-center justify-center gap-sp-3 rounded-md border border-navy-700 bg-navy-800 px-sp-5 py-sp-4 text-body font-semibold text-on-dark transition-colors duration-base hover:border-gold-500 hover:text-gold-300"
          >
            <span aria-hidden="true">📧</span>
            <span class="break-all">{brand.email}</span>
          </a>
        </li>
        <li>
          <a
            href={brand.kakaoChannelUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex min-h-[88px] w-full items-center justify-center gap-sp-3 rounded-md border border-navy-700 bg-navy-800 px-sp-5 py-sp-4 text-body font-semibold text-on-dark transition-colors duration-base hover:border-gold-500 hover:text-gold-300"
          >
            <span aria-hidden="true">📱</span>
            <span>카카오톡 채널 · {brand.kakaoChannelId}</span>
          </a>
        </li>
      </ul>

      <p class="mt-sp-8 text-body-sm text-on-dark-soft">
        {brand.legalName} · 대표 연락처 {brand.phone} (업무 시간: {brand.businessHours})
      </p>
      {
        business.representative !== '운영 준비 중' && (
          <p class="mt-sp-2 text-caption text-on-dark-soft">대표 {business.representative}</p>
        )
      }
    </div>
  </div>
</section>
