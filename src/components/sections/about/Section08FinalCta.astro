---
/*
 * /about Section 08 — 최종 CTA (08-about.md §9)
 * navy-950 · 무료 강의 우선, 본 강의 신청은 보조.
 * 현재 기수 표시는 campaign.ts 값 자동 반영.
 */
import { routes, campaign } from '@config/campaign';
---

<section class="bg-navy-950 text-on-dark">
  <div class="container-max py-sp-14 lg:py-sp-18">
    <div class="mx-auto max-w-[var(--container-narrow)] text-center">
      <h2 class="text-h1 font-bold leading-[1.2] text-paper reveal">
        이 수업이<br />
        대표님께 맞는지는 <span class="text-gold-400">1시간</span>이면 충분합니다.
      </h2>
      <p class="mx-auto mt-sp-5 max-w-[52ch] text-lead text-gold-300">
        사전 무료 강의에서 강사 톤, 커리큘럼 구조, 실집행 데이터까지
        모두 확인하실 수 있습니다.
      </p>

      <div class="mt-sp-10 flex flex-col items-center justify-center gap-sp-4 sm:flex-row">
        <a
          href={routes.free}
          class="inline-flex min-h-[56px] w-full items-center justify-center rounded-md bg-gold-500 px-sp-7 text-body font-bold text-navy-950 transition-colors duration-fast ease-standard hover:bg-gold-400 sm:w-auto sm:min-w-[280px]"
        >
          사전 무료 강의 신청 →
        </a>
        <a
          href={routes.apply}
          class="inline-flex min-h-[56px] w-full items-center justify-center rounded-md border border-gold-500/60 px-sp-7 text-body font-semibold text-gold-300 transition-colors duration-fast ease-standard hover:bg-navy-900 hover:text-paper sm:w-auto sm:min-w-[220px]"
        >
          수강 신청하기 →
        </a>
      </div>

      <p class="mt-sp-6 text-body-sm text-navy-400">
        현재 기수 {campaign.currentCount}/6명 · 다음 시작 예정일: {campaign.nextStartDate}
      </p>
    </div>
  </div>
</section>
