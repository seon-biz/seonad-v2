---
/*
 * /about Section 07 — 문의 폼 (08-about.md §8)
 *
 * paper · max-width 520px · 앵커 #contact-form
 * 필드: 이름 / 연락처 / 문의 유형(select) / 내용(textarea) / 약관 동의
 * 제출: FormSubmit.co AJAX (formspree.contactEndpoint · 수신자 brand.email)
 * 제출 성공 시 폼을 숨기고 같은 페이지에서 안내 패널 표시.
 * 제출 실패 시 카카오톡 채널로 이동 대체 안내 (§11-4).
 */
import { formspree, brand } from '@config/campaign';

const inquiryTypes = [
  '수강 신청 관련',
  '무료 강의 관련',
  '결제·세금계산서 관련',
  '환불 관련',
  '경쟁사 보호 정책 관련',
  '법인·단체 수강 관련',
  '기타',
];

const kakaoReady =
  brand.kakaoChannelUrl &&
  brand.kakaoChannelUrl !== 'http://pf.kakao.com/_';
---

<section id="contact-form" class="scroll-mt-[80px] bg-paper text-ink-900">
  <div class="container-max py-sp-14 lg:py-sp-18">
    <div class="mx-auto max-w-[520px]">
      <p class="text-caption font-bold tracking-[0.2em] text-ink-500 uppercase">
        CONTACT FORM
      </p>
      <h2 class="mt-sp-3 text-h3 font-bold leading-[1.3] text-ink-900 reveal">
        문의 폼으로 보내기.
      </h2>
      <p class="mt-sp-3 text-body-sm text-ink-500">
        4개 항목만 작성해주시면 48시간 이내에 답변드립니다.
      </p>

      <form
        id="contact-form-element"
        action={formspree.contactEndpoint}
        method="POST"
        class="mt-sp-8 flex flex-col gap-sp-5"
        novalidate
      >
        {/* 이름 */}
        <div class="flex flex-col gap-sp-2">
          <label for="contact-name" class="text-body-sm font-semibold text-ink-900">
            이름 <span class="text-danger" aria-hidden="true">*</span>
          </label>
          <input
            id="contact-name"
            name="name"
            type="text"
            required
            minlength="2"
            maxlength="40"
            autocomplete="name"
            placeholder="예: 홍길동"
            class="min-h-[48px] rounded-md border border-ink-300/60 bg-paper px-sp-4 text-body text-ink-900 placeholder:text-ink-300"
          />
          <p data-error-for="name" class="hidden text-caption text-danger" role="alert"></p>
        </div>

        {/* 연락처 */}
        <div class="flex flex-col gap-sp-2">
          <label for="contact-reply" class="text-body-sm font-semibold text-ink-900">
            답변 받을 연락처 (이메일 또는 카카오톡 ID) <span class="text-danger" aria-hidden="true">*</span>
          </label>
          <input
            id="contact-reply"
            name="reply_to"
            type="text"
            required
            maxlength="80"
            placeholder="예: abc@example.com 또는 카카오톡 ID"
            class="min-h-[48px] rounded-md border border-ink-300/60 bg-paper px-sp-4 text-body text-ink-900 placeholder:text-ink-300"
          />
          <p data-error-for="reply" class="hidden text-caption text-danger" role="alert"></p>
        </div>

        {/* 문의 유형 */}
        <div class="flex flex-col gap-sp-2">
          <label for="contact-type" class="text-body-sm font-semibold text-ink-900">
            문의 유형 <span class="text-danger" aria-hidden="true">*</span>
          </label>
          <select
            id="contact-type"
            name="inquiry_type"
            required
            class="min-h-[48px] rounded-md border border-ink-300/60 bg-paper px-sp-4 text-body text-ink-900"
          >
            <option value="">선택해주세요</option>
            {inquiryTypes.map((t) => <option value={t}>{t}</option>)}
          </select>
          <p data-error-for="type" class="hidden text-caption text-danger" role="alert"></p>
        </div>

        {/* 문의 내용 */}
        <div class="flex flex-col gap-sp-2">
          <label for="contact-message" class="text-body-sm font-semibold text-ink-900">
            문의 내용 <span class="text-danger" aria-hidden="true">*</span>
          </label>
          <textarea
            id="contact-message"
            name="message"
            required
            minlength="10"
            maxlength="1000"
            rows="6"
            placeholder="구체적인 상황을 적어주시면 정확한 답변이 가능합니다."
            class="rounded-md border border-ink-300/60 bg-paper px-sp-4 py-sp-3 text-body text-ink-900 placeholder:text-ink-300"
          ></textarea>
          <p class="text-right text-caption text-ink-500">
            <span id="contact-message-count">0</span> / 1000
          </p>
          <p data-error-for="message" class="hidden text-caption text-danger" role="alert"></p>
        </div>

        {/* 약관 동의 */}
        <label class="flex cursor-pointer items-start gap-sp-3 text-body-sm text-ink-700">
          <input
            id="contact-consent"
            name="consent"
            type="checkbox"
            required
            class="mt-[3px] h-[18px] w-[18px] shrink-0 accent-gold-500"
          />
          <span>
            <a
              href="/legal/privacy"
              class="text-gold-600 underline hover:text-gold-500"
            >
              개인정보처리방침
            </a>
            에 동의합니다 (필수)
          </span>
        </label>
        <p data-error-for="consent" class="hidden text-caption text-danger" role="alert"></p>

        {/* 봇 방지 honeypot — Formspree/FormSubmit 양쪽 호환 */}
        <input type="text" name="_gotcha" tabindex="-1" class="hidden" aria-hidden="true" />
        <input type="text" name="_honey" tabindex="-1" class="hidden" aria-hidden="true" />
        {/* FormSubmit 수신 메일 옵션 */}
        <input type="hidden" name="_subject" value={formspree.subjects.contact} />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="source" value="/about" />

        {/* 제출 */}
        <button
          id="contact-submit"
          type="submit"
          disabled
          aria-disabled="true"
          class="mt-sp-3 inline-flex min-h-[56px] items-center justify-center rounded-md bg-gold-500 px-sp-6 text-body font-bold text-navy-950 transition-colors duration-fast ease-standard hover:bg-gold-400 disabled:cursor-not-allowed disabled:bg-ink-300/50 disabled:text-ink-500"
        >
          문의 보내기 →
        </button>

        <p
          id="contact-submit-status"
          role="status"
          aria-live="polite"
          class="text-caption text-ink-500"
        ></p>
      </form>

      {/* 성공 패널 */}
      <div
        id="contact-success"
        class="mt-sp-8 hidden rounded-md border border-gold-500/40 bg-paper-soft p-sp-6"
        role="status"
        aria-live="polite"
      >
        <p class="text-caption font-bold tracking-[0.18em] text-gold-600 uppercase">
          ✓ 문의가 접수되었습니다
        </p>
        <p class="mt-sp-3 text-body leading-[1.7] text-ink-700">
          <span id="contact-success-name" class="font-bold text-ink-900">고객</span>님,
          문의 주셔서 감사합니다.<br />
          <span id="contact-success-reply" class="font-semibold text-ink-900">입력하신 연락처</span>로
          48시간 이내에 답변드리겠습니다.
        </p>
        <p class="mt-sp-4 text-body-sm text-ink-500">
          급한 건이시면 카카오톡 채널로 다시 한번 연락주시면 더 빠르게 확인 가능합니다.
        </p>
        {kakaoReady && (
          <a
            href={brand.kakaoChannelUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-sp-5 inline-flex min-h-[44px] items-center justify-center rounded-md border border-gold-500 px-sp-5 text-body-sm font-bold text-gold-600 hover:bg-gold-100/40"
          >
            카카오톡 채널 바로가기 →
          </a>
        )}
      </div>

      {/* 실패 패널 */}
      <div
        id="contact-fail"
        class="mt-sp-5 hidden rounded-md border border-danger/50 bg-danger/5 p-sp-5 text-body-sm text-ink-900"
        role="alert"
      >
        <p class="font-semibold">
          전송 중 문제가 발생했습니다.
        </p>
        <p class="mt-sp-2 text-ink-700">
          잠시 후 다시 시도해주시거나,
          <a href={`mailto:${brand.email}`} class="underline">
            {brand.email}
          </a>
          또는 카카오톡 채널로 직접 문의 주시면 빠르게 답변드립니다.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const form = document.getElementById('contact-form-element') as HTMLFormElement | null;
    if (!form) return;

    const nameEl = document.getElementById('contact-name') as HTMLInputElement;
    const replyEl = document.getElementById('contact-reply') as HTMLInputElement;
    const typeEl = document.getElementById('contact-type') as HTMLSelectElement;
    const msgEl = document.getElementById('contact-message') as HTMLTextAreaElement;
    const consentEl = document.getElementById('contact-consent') as HTMLInputElement;
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;
    const statusEl = document.getElementById('contact-submit-status') as HTMLParagraphElement;
    const countEl = document.getElementById('contact-message-count') as HTMLSpanElement;
    const successEl = document.getElementById('contact-success') as HTMLDivElement;
    const failEl = document.getElementById('contact-fail') as HTMLDivElement;

    function isValid() {
      return (
        nameEl.value.trim().length >= 2 &&
        replyEl.value.trim().length > 0 &&
        typeEl.value !== '' &&
        msgEl.value.trim().length >= 10 &&
        consentEl.checked
      );
    }

    function syncSubmit() {
      const ok = isValid();
      submitBtn.disabled = !ok;
      submitBtn.setAttribute('aria-disabled', ok ? 'false' : 'true');
    }

    function updateCount() {
      countEl.textContent = String(msgEl.value.length);
    }

    [nameEl, replyEl, typeEl, msgEl].forEach((el) =>
      el.addEventListener('input', syncSubmit),
    );
    typeEl.addEventListener('change', syncSubmit);
    consentEl.addEventListener('change', syncSubmit);
    msgEl.addEventListener('input', updateCount);
    syncSubmit();

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!isValid()) {
        statusEl.textContent = '필수 항목을 모두 입력해주세요.';
        return;
      }
      const endpoint = form.getAttribute('action') || '';
      if (!endpoint) {
        statusEl.textContent =
          '문의 폼이 아직 연결되지 않았습니다. 이메일 또는 카카오톡 채널로 연락해주세요.';
        failEl.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.setAttribute('aria-disabled', 'true');
      statusEl.textContent = '전송 중…';
      failEl.classList.add('hidden');

      try {
        const data = new FormData(form);
        const res = await fetch(endpoint, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (!res.ok) throw new Error(String(res.status));

        form.classList.add('hidden');
        statusEl.textContent = '';
        const sName = document.getElementById('contact-success-name');
        const sReply = document.getElementById('contact-success-reply');
        if (sName) sName.textContent = nameEl.value.trim();
        if (sReply) sReply.textContent = replyEl.value.trim();
        successEl.classList.remove('hidden');
        successEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } catch (_err) {
        statusEl.textContent = '';
        failEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.setAttribute('aria-disabled', 'false');
      }
    });
  })();
</script>
