---
/*
 * /about Section 06 — 문의 3채널 카드 (08-about.md §7)
 *
 * paper-soft · 3카드 (카카오톡 채널 / 이메일 / 문의 폼).
 * §11-3: 카드 높이 동일, CTA 사이즈 통일.
 * 카카오톡 채널 URL 이 기본 플레이스홀더일 때 "준비 중" 표기 — 단, 카드 전체를
 * 비활성화하지 않고 이메일/폼은 여전히 작동하도록 유지.
 */
import { brand } from '@config/campaign';

const kakaoReady =
  brand.kakaoChannelUrl &&
  brand.kakaoChannelUrl !== 'http://pf.kakao.com/_';

const cards = [
  {
    icon: 'kakao',
    title: '카카오톡 채널',
    description: '가장 빠른 응답 채널. 평균 2~4시간 이내 답변.',
    ctaLabel: kakaoReady ? '카카오톡 채널 추가 →' : '카카오톡 채널 준비 중',
    href: kakaoReady ? brand.kakaoChannelUrl : null,
    external: true,
  },
  {
    icon: 'mail',
    title: '이메일 문의',
    description: '자세한 상담이나 첨부 파일이 필요할 때. 24시간 이내 답변.',
    ctaLabel: '메일 보내기 →',
    href: `mailto:${brand.email}`,
    external: false,
  },
  {
    icon: 'form',
    title: '문의 폼',
    description: '이메일 없이도 이 페이지에서 바로. 48시간 이내 답변.',
    ctaLabel: '아래 문의 폼으로 이동 ↓',
    href: '#contact-form',
    external: false,
  },
] as const;
---

<section class="bg-paper-soft text-ink-900" aria-labelledby="about-contact-heading">
  <div class="container-max py-sp-14 lg:py-sp-18">
    <div class="mx-auto max-w-[60ch] text-center">
      <h2
        id="about-contact-heading"
        class="text-h2 font-bold leading-[1.3] text-ink-900 reveal"
      >
        궁금한 것이 있다면.
      </h2>
      <p class="mt-sp-4 text-body text-ink-500">
        FAQ에 답이 없거나 구체 상황을 상담하고 싶으시면
        아래 3가지 채널 중 편한 곳으로 언제든지 연락 주세요.
      </p>
    </div>

    <ul class="mx-auto mt-sp-10 grid max-w-[var(--container-wide)] gap-sp-5 md:grid-cols-3">
      {
        cards.map((card) => (
          <li class="reveal h-full">
            <article class="flex h-full flex-col rounded-md border border-ink-300/40 bg-paper p-sp-6 lg:p-sp-7">
              {/* 아이콘 — 골드 라인아트 */}
              <div
                class="inline-flex h-[44px] w-[44px] items-center justify-center rounded-md border border-gold-500/40 bg-gold-100/40 text-gold-600"
                aria-hidden="true"
              >
                {card.icon === 'kakao' && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-[22px] w-[22px]"
                  >
                    <path d="M12 4C6.48 4 2 7.58 2 12c0 2.62 1.55 4.95 3.95 6.42L5 22l3.89-2.17c.99.14 2.02.21 3.11.21 5.52 0 10-3.58 10-8S17.52 4 12 4Z" />
                  </svg>
                )}
                {card.icon === 'mail' && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-[22px] w-[22px]"
                  >
                    <rect x="3" y="5" width="18" height="14" rx="2" />
                    <path d="m3 7 9 6 9-6" />
                  </svg>
                )}
                {card.icon === 'form' && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-[22px] w-[22px]"
                  >
                    <path d="M7 3h8l4 4v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1Z" />
                    <path d="M15 3v4h4" />
                    <path d="M9 13h6M9 17h4" />
                  </svg>
                )}
              </div>

              <h3 class="mt-sp-4 text-h4 font-bold text-ink-900">
                {card.title}
              </h3>
              <p class="mt-sp-2 text-body leading-[1.7] text-ink-700">
                {card.description}
              </p>

              <div class="mt-auto pt-sp-5">
                {card.href ? (
                  <a
                    href={card.href}
                    {...(card.external && card.href?.startsWith('http')
                      ? { target: '_blank', rel: 'noopener noreferrer' }
                      : {})}
                    class="inline-flex min-h-[44px] w-full items-center justify-center rounded-md bg-gold-500 px-sp-5 text-body-sm font-bold text-navy-950 transition-colors duration-fast ease-standard hover:bg-gold-400"
                  >
                    {card.ctaLabel}
                  </a>
                ) : (
                  <span
                    aria-disabled="true"
                    class="inline-flex min-h-[44px] w-full items-center justify-center rounded-md border border-ink-300/50 bg-paper-soft px-sp-5 text-body-sm font-semibold text-ink-500"
                  >
                    {card.ctaLabel}
                  </span>
                )}
              </div>
            </article>
          </li>
        ))
      }
    </ul>
  </div>
</section>
