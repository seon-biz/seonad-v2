---
/*
 * 02-main-page.md §3 — 섹션 2 문제 제기
 * 배경: paper-soft / 목적: 페르소나 1(초행형)·2(실패형) 동시 타격
 */

const symptoms = [
  {
    quote: '"파워링크? 쇼핑검색? 이게 다 뭔 말이야"',
    caption: '용어가 막혀서 시작조차 못 하는 상태',
  },
  {
    quote: '"잘못 눌러서 돈 나갈까 봐 무서워요"',
    caption: '비즈센터 UI 앞에서 멈춘 상태',
  },
  {
    quote: '"광고 켰더니 돈만 빠지고 주문은 없어요"',
    caption: '한 번 켜봤다가 바로 끈 상태',
  },
  {
    quote: '"대행사가 뭐라는지 알아듣질 못해요"',
    caption: '맡겨도 주도권을 못 쥐는 상태',
  },
];
---

<section id="section-problem" class="bg-paper-soft text-ink-900">
  <div class="container-max section-y">
    {/* 헤더 */}
    <div class="mx-auto max-w-[36ch] text-center">
      <h2 class="text-h2 font-bold text-ink-900">
        광고는 켜야 할 것 같은데,<br />
        시작하면 돈만 빠질 것 같고.
      </h2>
      <p class="mt-sp-4 text-lead text-ink-700">
        스마트스토어 셀러 대부분이 이 지점에서 멈춥니다.
      </p>
      <p class="mt-sp-3 text-body-sm text-ink-500">
        대상: 완전 초보 스마트스토어 셀러 · 월 광고비 30만 원 이상 운영을 고려 중인 대표님
      </p>
    </div>

    {/* 증상 카드 4장 (2x2 데스크톱 / 1열 모바일) */}
    <ul class="mt-sp-7 grid grid-cols-1 gap-sp-4 md:grid-cols-2 md:gap-sp-5">
      {
        symptoms.map((s, i) => (
          <li class="rounded-lg border border-ink-300/40 bg-paper p-sp-5 shadow-xs md:p-sp-6">
            <div class="flex items-start gap-sp-4">
              {/* 라인아트 아이콘 — 인덱스별 단순 글리프(골드) */}
              <span
                aria-hidden="true"
                class="mt-sp-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-gold-500 text-gold-600"
              >
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  {i === 0 && (
                    <>
                      <circle cx="8" cy="8" r="5" stroke="currentColor" stroke-width="1.4" />
                      <line x1="12" y1="12" x2="15.5" y2="15.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                    </>
                  )}
                  {i === 1 && (
                    <>
                      <path d="M9 2 L15 6 V10 C15 13.5 12 15.5 9 16 C6 15.5 3 13.5 3 10 V6 Z" stroke="currentColor" stroke-width="1.4" fill="none" />
                      <line x1="9" y1="7" x2="9" y2="11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                      <circle cx="9" cy="13" r="0.8" fill="currentColor" />
                    </>
                  )}
                  {i === 2 && (
                    <>
                      <path d="M2 13 L7 8 L10 11 L16 5" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" />
                      <polyline points="12,5 16,5 16,9" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round" />
                    </>
                  )}
                  {i === 3 && (
                    <>
                      <path d="M3 6 C3 4.5 4 3.5 5.5 3.5 H12.5 C14 3.5 15 4.5 15 6 V10.5 C15 12 14 13 12.5 13 H8 L5 15.5 V13 H5.5 C4 13 3 12 3 10.5 Z" stroke="currentColor" stroke-width="1.3" fill="none" />
                    </>
                  )}
                </svg>
              </span>
              <div>
                <p class="text-h4 font-semibold text-ink-900">
                  {s.quote}
                </p>
                <p class="mt-sp-2 text-body text-ink-500">
                  {s.caption}
                </p>
              </div>
            </div>
          </li>
        ))
      }
    </ul>

    {/* 섹션 전환 문구 */}
    <p class="mt-sp-7 text-center text-lead text-ink-500">
      문제는 "광고를 모른다"가 아닙니다.<br />
      누가 내 계정을 같이 봐주지 않는다는 것입니다.
    </p>
  </div>
</section>
