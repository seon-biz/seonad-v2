---
/*
 * 02-main-page.md §9 — 섹션 8 제공 자료 시각화
 * 배경: cream / 목적: 70만 원에 들어있는 "만질 수 있는 자산" 증명
 */
import WireframeCard from '@components/ui/WireframeCard.astro';

const materials = [
  {
    title: '워크북 PDF (60~80페이지)',
    wire: { label: 'WORKBOOK · PDF', caption: '세온애드 워크북 v1' },
    items: [
      'PART 1 광고 시작 전 진단 워크시트',
      'PART 2 쇼핑검색광고 설계 워크시트',
      'PART 3 파워링크 키워드 워크시트',
      'PART 4 줌 수업 준비 시트',
      'PART 5 30일 운영 플랜 작성지',
    ],
  },
  {
    title: '광고 성과 체크리스트 3종',
    wire: { label: 'CHECKLIST · 3종', caption: '일 · 주 · 월' },
    items: [
      '일간 체크리스트 (5분) — 어제 지표 4개 + 정상 범위 기준',
      '주간 체크리스트 (30분) — 그룹별 ROAS 순위 + 입찰 조정',
      '월간 체크리스트 (2시간) — 전체 구조 점검 + 예산 계획',
    ],
  },
  {
    title: '광고 운영 AI 도우미',
    wire: { label: 'GPTs · GEMs', caption: 'AI 보조 2종' },
    items: [
      '광고 소재 작성 도우미 (파워링크 제목·설명 5종 자동 생성)',
      '키워드 분석 도우미 (대표 → 세부 → 구매의도 분류)',
      'GPTs · GEMs 링크 모두 제공',
    ],
  },
];
---

<section id="section-materials" class="bg-cream text-ink-900">
  <div class="container-max section-y">
    <div class="mx-auto max-w-[40ch] text-center">
      <h2 class="text-h2 font-bold">
        강의가 끝나면<br />
        손에 운영 매뉴얼 한 권이 남습니다.
      </h2>
    </div>

    <ul class="mt-sp-7 grid grid-cols-1 gap-sp-5 md:grid-cols-2 lg:grid-cols-3">
      {
        materials.map((m) => (
          <li class="flex flex-col gap-sp-5 rounded-lg border border-gold-500/40 bg-paper p-sp-5 shadow-xs md:p-sp-6">
            <WireframeCard variant="soft" label={m.wire.label} caption={m.wire.caption} aspect="wide" />
            <h3 class="text-h4 font-semibold">{m.title}</h3>
            <ul class="flex flex-col gap-sp-2 text-body text-ink-700">
              {m.items.map((item) => (
                <li class="flex items-start gap-sp-3">
                  <span class="mt-[8px] h-[6px] w-[6px] shrink-0 rounded-full bg-gold-500" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </li>
        ))
      }
    </ul>
  </div>
</section>
