---
/*
 * 02-main-page.md §5 — 섹션 4 커리큘럼 요약 (4주 구조)
 * 배경: paper-soft / 목적: 4주 동안 무엇을 하는지 한 장 납득
 */
import { routes } from '@config/campaign';

const weeks = [
  {
    label: 'WEEK 1',
    format: 'VOD',
    title: 'PART 1 — 광고 시작 전 지도 + 계정 세팅',
    meta: '1~2강 · 60분',
  },
  {
    label: 'WEEK 2',
    format: 'VOD',
    title: 'PART 2~3 — 쇼핑검색·파워링크·브랜드검색',
    meta: '3~7강 + 부록 · 180분',
  },
  {
    label: 'WEEK 3',
    format: '줌 2시간',
    title: '계정 세팅 검수 + 첫 쇼핑검색광고 발행',
    meta: 'ZOOM LIVE · 120분',
  },
  {
    label: 'WEEK 4',
    format: '줌 2시간',
    title: '7일 성과 그룹 진단 + 파워링크 발행 + 30일 플랜',
    meta: 'ZOOM LIVE · 120분',
  },
];
---

<section id="section-curriculum-summary" class="bg-paper-soft text-ink-900">
  <div class="container-max section-y">
    <div class="mx-auto max-w-[44ch] text-center">
      <h2 class="text-h2 font-bold">4주 커리큘럼 한눈에.</h2>
      <p class="mt-sp-3 text-body text-ink-500">
        쇼핑검색광고 메인, 파워링크·브랜드검색 서브로 4주 과정을 설계했습니다.
      </p>
    </div>

    {/* 4주 타임라인 — 가로 4칸(데스크톱), 세로 스택(모바일) */}
    <ol class="mt-sp-7 grid grid-cols-1 gap-sp-4 md:grid-cols-2 lg:grid-cols-4 lg:gap-sp-5">
      {
        weeks.map((w, idx) => (
          <li class="relative flex flex-col rounded-lg border border-ink-300/40 bg-paper p-sp-5 shadow-xs">
            <div class="flex items-center justify-between">
              <span class="pill pill-gold tracking-eyebrow">
                {w.label}
              </span>
              <span class="text-caption font-semibold text-ink-500">
                {w.format}
              </span>
            </div>
            <h3 class="mt-sp-4 text-h4 font-semibold text-ink-900">
              {w.title}
            </h3>
            <p class="mt-sp-3 text-body-sm text-ink-500">{w.meta}</p>

            {/* 데스크톱 전용: 주차 간 연결선 화살표 */}
            {idx < weeks.length - 1 && (
              <span
                aria-hidden="true"
                class="absolute right-[-18px] top-1/2 hidden h-px w-[18px] -translate-y-1/2 bg-gold-500 lg:block"
              />
            )}
          </li>
        ))
      }
    </ol>

    {/* 하단 애프터케어 바 */}
    <div class="mt-sp-6 rounded-lg border border-gold-500 bg-navy-900 p-sp-4 text-on-dark md:p-sp-5">
      <p class="text-center text-lead text-gold-300">
        + 강의 시작일 기준 3개월 애프터케어 (단톡방 + 점검 줌 1시간)
      </p>
    </div>

    <div class="mt-sp-6 flex justify-center">
      <a href={routes.curriculum} class="btn-base btn-secondary-light">
        커리큘럼 강의별 상세 보기 →
      </a>
    </div>
  </div>
</section>
