---
/*
 * /free Section 08 — 최종 CTA (07-free.md §9)
 *
 *  - navy-950 배경 중앙 정렬
 *  - Primary: "무료 강의 신청하기 ↑" → #signup-form (같은 페이지 앵커)
 *  - Secondary: "이미 마음이 섰다면, 수강 신청하기 →" → /apply
 *  - 하단 cadence 문구
 */
import { routes, freeClass } from '@config/campaign';
---

<section class="bg-navy-950 text-on-dark">
  <div class="container-max section-y">
    <div class="mx-auto max-w-[760px] text-center">
      <h2 class="text-h1 font-bold leading-tight text-paper">
        1시간으로<br />
        결제 결정 근거를 확보하십시오.
      </h2>
      <p class="mt-sp-5 text-lead text-gold-300">
        무료 강의에 올려진 것은 커리큘럼 요약이 아니라<br />
        실제 4개 업체의 집행 데이터입니다.
      </p>

      <div class="mt-sp-10 flex flex-col items-center justify-center gap-sp-4 sm:flex-row">
        <a
          href="#signup-form"
          data-anchor-smooth
          class="inline-flex min-h-[56px] min-w-[260px] items-center justify-center rounded-md bg-gold-500 px-sp-7 text-body font-bold text-navy-950 transition-colors duration-base hover:bg-gold-400"
        >
          무료 강의 신청하기 ↑
        </a>
        <a
          href={routes.apply}
          class="inline-flex min-h-[56px] min-w-[260px] items-center justify-center rounded-md border border-gold-500 bg-transparent px-sp-7 text-body font-bold text-gold-300 transition-colors duration-base hover:bg-gold-500/10 hover:text-gold-100"
        >
          이미 마음이 섰다면, 수강 신청하기 →
        </a>
      </div>

      <p class="mt-sp-8 text-body-sm text-on-dark-soft">
        무료 강의는 <span class="font-semibold text-gold-300">{freeClass.cadence}</span> 정기적으로 운영됩니다.
        신청 시점에 따라 가장 가까운 일정으로 배정됩니다.
      </p>
    </div>
  </div>
</section>
