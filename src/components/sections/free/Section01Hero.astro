---
/*
 * /free Section 01 — Hero (07-free.md §2)
 *
 * - navy-950 다크 프레임, container-narrow, min-h 70vh (lg 이상)
 * - 브레드크럼 · FREE·ZOOM LIVE 라벨 · hero 카피(4개 업체 실광고 성과)
 * - 4개 정보 블록 그리드 (60분 · 무료 · 4개 업체 NDA · 녹화본)
 * - 다음 강의 일정 박스: campaign.freeClass.displayDatetime
 *     · status='tba' 이거나 ISO 가 과거면 JS 가 tbaMessage 로 치환
 * - Primary CTA → #signup-form 앵커 스크롤
 * - Secondary 안내: 폼 30초 설명
 */
import { freeClass, campaign } from '@config/campaign';
import { routes } from '@config/campaign';
---

<section class="bg-navy-950 text-on-dark">
  <div class="mx-auto w-full max-w-[var(--container-narrow)] px-sp-5 py-sp-16 lg:min-h-[70vh] lg:py-sp-20">
    <nav aria-label="브레드크럼" class="text-caption text-navy-400">
      <ol class="flex items-center gap-sp-2">
        <li>
          <a href={routes.home} class="hover:text-gold-300">세온애드</a>
        </li>
        <li aria-hidden="true">›</li>
        <li aria-current="page" class="text-on-dark-soft">사전 무료 강의</li>
      </ol>
    </nav>

    <p class="mt-sp-6 text-caption font-bold tracking-[0.2em] text-gold-400">
      FREE · ZOOM LIVE {freeClass.durationLabel}
    </p>

    <h1 class="mt-sp-4 text-hero font-bold leading-[1.15] text-paper">
      4개 업체의 실제 광고 성과를<br />
      <span class="text-gold-400">1시간 안에</span> 공개합니다.
    </h1>

    <p class="mt-sp-5 max-w-[60ch] text-lead text-gold-300">
      NDA 조건 하에, 업종·운영 기간·ROAS·월 광고비까지.<br />
      줌 라이브 1시간, 신청자 누구나 시청 가능합니다.
    </p>

    {/* 정보 블록 4칸 */}
    <ul class="mt-sp-10 grid grid-cols-2 gap-sp-3 lg:grid-cols-4 lg:gap-sp-4">
      {
        [
          { icon: '🎥', value: '60분', label: '줌 라이브 강의' },
          { icon: '🎁', value: '무료', label: '신청자 누구나' },
          { icon: '🔒', value: '4개 업체', label: '실집행 성과 NDA 공개' },
          { icon: '📼', value: '녹화본', label: '신청자 한정 다시보기' },
        ].map((b) => (
          <li class="rounded-md border border-navy-700 bg-navy-900/60 p-sp-4">
            <div class="text-h3 leading-none" aria-hidden="true">
              {b.icon}
            </div>
            <p class="mt-sp-3 text-h4 font-bold text-gold-300">{b.value}</p>
            <p class="mt-sp-1 text-caption text-on-dark-soft">{b.label}</p>
          </li>
        ))
      }
    </ul>

    {/* 다음 강의 일정 박스 */}
    <div
      id="free-next-class"
      data-free-iso={freeClass.isoDatetime}
      data-free-status={freeClass.status}
      class="mt-sp-8 rounded-md border border-gold-500/40 bg-navy-800 p-sp-5"
    >
      <p class="text-caption font-semibold uppercase tracking-[0.14em] text-gold-400">
        <span aria-hidden="true">📅</span>{' '}다음 강의 일정
      </p>
      <p
        id="free-next-class-text"
        class="mt-sp-3 text-h4 font-bold text-paper"
      >
        {freeClass.status === 'tba'
          ? freeClass.tbaMessage
          : `${freeClass.displayDatetime} · 줌 라이브`}
      </p>
      <p
        id="free-next-class-heads-up"
        class="mt-sp-3 hidden text-body-sm text-on-dark-soft"
      >
        일정이 가까워지면 이메일과 카카오톡으로 알림을 드립니다.
      </p>
      <p class="mt-sp-4 text-caption text-navy-400">
        {campaign.status === 'recruiting'
          ? `${freeClass.cadence} 정기 운영 · 본 강의 1기 ${campaign.currentCount}명 모집 진행 중`
          : `${freeClass.cadence} 정기 운영`}
      </p>
    </div>

    {/* 메인 CTA */}
    <div class="mt-sp-10">
      <a
        href="#signup-form"
        data-anchor-smooth
        class="inline-flex min-h-[60px] w-full items-center justify-center rounded-md bg-gold-500 px-sp-8 text-body font-bold text-navy-950 transition-colors duration-base hover:bg-gold-400 sm:w-auto sm:min-w-[400px]"
      >
        무료 강의 신청하기 ↓
      </a>
      <p class="mt-sp-4 text-body-sm text-navy-400">
        ※ 신청 폼은 이메일 또는 카카오톡 ID 하나만 받습니다. 작성 30초.
      </p>
    </div>
  </div>
</section>
