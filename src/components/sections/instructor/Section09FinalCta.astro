---
/*
 * 04-instructor.md §10 — 최종 CTA
 *
 * - 배경 navy-950 / h1 + lead + CTA 2종 + 하단 기수 캡션
 * - 페이드업 대상
 */
import { campaign, routes } from '@config/campaign';
---

<section class="bg-navy-950 text-on-dark">
  <div class="container-narrow section-y text-center">
    <h2 class="reveal text-h1 font-bold text-white">
      이 4주,<br />
      대표님 옆자리에 앉겠습니다.
    </h2>

    <p class="reveal reveal-delay-1 mx-auto mt-sp-5 max-w-[52ch] text-lead text-gold-300">
      직접 만나보고 판단하고 싶다면 사전 무료 강의부터.<br />
      이미 마음이 서셨다면 바로 수강 신청하셔도 됩니다.
    </p>

    <div
      class="reveal reveal-delay-2 mt-sp-7 flex flex-col items-center justify-center gap-sp-3 sm:flex-row"
    >
      <a href={routes.free} class="btn-base btn-primary btn-lg">
        사전 무료 강의 신청 →
      </a>
      <a href={routes.apply} class="btn-base btn-secondary btn-lg">
        수강 신청하기 →
      </a>
    </div>

    <p class="reveal reveal-delay-3 mt-sp-6 text-body-sm text-on-dark-soft">
      한 기수 6명. 현재 기수 {campaign.currentCount}명 · 다음 시작 예정일:{' '}
      {campaign.nextStartDate}
    </p>
  </div>
</section>
