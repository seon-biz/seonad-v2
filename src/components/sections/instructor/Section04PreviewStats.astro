---
/*
 * 04-instructor.md §5 — 4개 업체 실집행 실적 예고
 *
 * - 배경 paper-soft / 원칙: 이 페이지에서는 숫자 비공개(무료 강의 리드 유인용)
 * - 2×2 그리드 (모바일 1열)
 * - §12-4: blur-filter 금지. 골드 자물쇠 SVG + "사전 무료 강의에서 공개" 텍스트로 표현
 * - CTA: 사전 무료 강의 신청 (→ /free) + 캡션
 */
import { routes } from '@config/campaign';

const businesses = [
  { industry: '생활용품 스마트스토어' },
  { industry: '식품·건강 스마트스토어' },
  { industry: '패션 스마트스토어' },
  { industry: '리빙·인테리어 스마트스토어' },
];

const fields = [
  { label: '운영 기간' },
  { label: 'ROAS' },
  { label: '월 광고비' },
];
---

<section class="bg-paper-soft text-ink-900">
  <div class="container-max section-y">
    <div class="mx-auto max-w-[60ch] text-center">
      <p class="eyebrow text-ink-500">실집행 실적</p>
      <h2 class="mt-sp-4 text-h2 font-bold text-ink-900">
        실제로 집행한 4개 업체의 광고 성과.<br />
        사전 무료 강의 1시간에서 공개합니다.
      </h2>
      <p class="mt-sp-4 text-lead text-ink-500">
        NDA(비밀유지) 조건 하에, 업체명과 구체 수치까지 모두 보여드립니다.<br
          class="hidden md:inline"
        />
        이 페이지에서는 업종과 조건만 미리 알려드립니다.
      </p>
    </div>

    <ul class="mt-sp-8 grid grid-cols-1 gap-sp-5 md:grid-cols-2">
      {
        businesses.map((b, idx) => (
          <li class="rounded-lg border border-ink-300/40 bg-paper p-sp-6">
            <div class="flex items-center justify-between">
              <span class="text-caption tracking-caption text-ink-500">
                CASE {String(idx + 1).padStart(2, '0')}
              </span>
              <span class="inline-flex items-center gap-sp-1 text-caption text-gold-600">
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 14 14"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M3.5 6.5V4.5a3.5 3.5 0 0 1 7 0v2M3 6.5h8v6H3v-6Z"
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                공개 예정
              </span>
            </div>

            <dl class="mt-sp-4 flex flex-col gap-sp-3">
              <div class="flex items-baseline justify-between gap-sp-4">
                <dt class="text-caption tracking-caption text-ink-500">업종</dt>
                <dd class="text-body font-semibold text-ink-900">
                  {b.industry}
                </dd>
              </div>
              {fields.map((f) => (
                <div class="flex items-baseline justify-between gap-sp-4 border-t border-ink-300/40 pt-sp-3">
                  <dt class="text-caption tracking-caption text-ink-500">
                    {f.label}
                  </dt>
                  <dd class="inline-flex items-center gap-sp-2 text-body font-semibold text-gold-600">
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 14 14"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path
                        d="M3.5 6.5V4.5a3.5 3.5 0 0 1 7 0v2M3 6.5h8v6H3v-6Z"
                        stroke="currentColor"
                        stroke-width="1.4"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    사전 무료 강의에서 공개
                  </dd>
                </div>
              ))}
            </dl>

            <p class="mt-sp-4 text-body-sm text-gold-600">
              → 무료 강의에서 공개
            </p>
          </li>
        ))
      }
    </ul>

    <div class="mx-auto mt-sp-8 flex max-w-[560px] flex-col items-center gap-sp-3 text-center">
      <p class="text-caption tracking-caption text-gold-600">
        — 사전 무료 강의에서 4개 업체 광고 성과 공개 —
      </p>
      <a href={routes.free} class="btn-base btn-primary btn-lg">
        사전 무료 강의 신청 →
      </a>
      <p class="text-body-sm text-ink-500">
        신청자 누구나 시청 가능. 일정은 카카오톡으로 안내됩니다.
      </p>
    </div>
  </div>
</section>
