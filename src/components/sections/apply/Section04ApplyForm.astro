---
/*
 * 05-pricing-apply.md §5 — 신청 폼 (이 페이지의 핵심)
 *
 * - 앵커: #apply-form (메인 페이지 CTA 직접 점프 대응)
 * - 폭 640px (§5-1: container-narrow 보다 좁게, 집중도)
 * - 필수 3(이름/연락처/카테고리) + 선택 3 + 세금계산서(+3) + 약관 3
 * - 동적 필드(§10-1·3·4)
 *   · 카테고리 "기타" 선택 → 텍스트 입력 노출
 *   · 세금계산서 체크 → 하위 3필드 노출
 *   · 사업자번호 하이픈 자동 포맷
 * - 필수 3 + 약관 3 충족 시에만 제출 버튼 활성화 (§5-4 / §10-4-3)
 * - 제출 성공 시 같은 페이지 내 성공 화면으로 교체 (§5-5)
 * - 초기 백엔드는 Formspree (§5-6). endpoint 는 config/campaign.ts 에서 중앙 관리.
 */
import {
  brand,
  campaign,
  formspree,
  routes,
  smartstoreCategories,
} from '@config/campaign';

const endpoint = formspree.endpoint;
const agreementLinks = {
  accountPolicy:
    '수강 중 본인 광고 계정을 동기 5명에게 공개하는 것에 동의합니다',
  competitorPolicy:
    '동일 카테고리 경쟁 셀러가 겹칠 경우 이월 또는 환불 정책 적용에 동의합니다',
};
---

<section id="apply-form-section" class="bg-paper-soft text-ink-900">
  <div class="container-max section-y">
    {/* 섹션 헤더 */}
    <div class="mx-auto max-w-[640px]">
      <p class="eyebrow text-ink-500">신청 폼</p>
      <h2 class="mt-sp-4 text-h2 font-bold text-ink-900">수강 신청하기.</h2>
      <p class="mt-sp-3 text-body text-ink-500">
        필수 3개 + 선택 4개 = 최대 3분. 신청 후 카카오톡으로 진행 안내를 받으십니다.
      </p>
    </div>

    {/* 앵커는 스티키 헤더 보정을 위해 섹션 헤더 위쪽에 별도 placeholder 로 배치 */}
    <span id="apply-form" class="block scroll-mt-[96px]" aria-hidden="true"></span>

    {/* ==================== FORM ==================== */}
    <form
      id="apply-form-element"
      action={endpoint}
      method="POST"
      novalidate
      class="mx-auto mt-sp-8 max-w-[640px] rounded-lg border border-ink-300/40 bg-paper p-sp-6 lg:p-sp-7"
    >
      {/* Formspree honeypot 및 제목 */}
      <input type="text" name="_gotcha" tabindex="-1" class="hidden" aria-hidden="true" />
      <input type="hidden" name="_subject" value="[세온애드] 수강 신청이 접수되었습니다" />

      {/* ---------- 필수 섹션 ---------- */}
      <fieldset class="flex flex-col gap-sp-5">
        <legend class="text-caption font-semibold tracking-caption text-gold-600">
          필수 정보
        </legend>

        {/* 필드 1 — 이름 */}
        <div class="flex flex-col gap-sp-2">
          <label for="field-name" class="text-body-sm font-semibold text-ink-900">
            이름 (실명)
            <span aria-hidden="true" class="ml-sp-1 text-danger">*</span>
          </label>
          <input
            id="field-name"
            name="name"
            type="text"
            required
            minlength="2"
            maxlength="20"
            pattern="[가-힣A-Za-z\s]+"
            autocomplete="name"
            placeholder="예: 홍길동"
            class="form-input"
            data-required
          />
          <p class="text-caption text-ink-500">
            세금계산서 발행 또는 환불 시 신분 확인에 사용됩니다.
          </p>
          <p class="form-error hidden text-caption text-danger" data-error-for="field-name" role="alert"></p>
        </div>

        {/* 필드 2 — 연락처 */}
        <div class="flex flex-col gap-sp-2">
          <label for="field-contact" class="text-body-sm font-semibold text-ink-900">
            카카오톡 오픈채팅 ID 또는 휴대폰 번호
            <span aria-hidden="true" class="ml-sp-1 text-danger">*</span>
          </label>
          <input
            id="field-contact"
            name="contact"
            type="text"
            required
            minlength="9"
            placeholder="예: 010-1234-5678 또는 카카오톡 ID"
            class="form-input"
            data-required
          />
          <p class="text-caption text-ink-500">
            신청 후 이 경로로 안내드립니다. 카카오톡 ID를 권장드립니다.
          </p>
          <p class="form-error hidden text-caption text-danger" data-error-for="field-contact" role="alert"></p>
        </div>

        {/* 필드 3 — 카테고리 */}
        <div class="flex flex-col gap-sp-2">
          <label for="field-category" class="text-body-sm font-semibold text-ink-900">
            주력 판매 카테고리
            <span aria-hidden="true" class="ml-sp-1 text-danger">*</span>
          </label>
          <select
            id="field-category"
            name="category"
            required
            class="form-input"
            data-required
          >
            <option value="">선택해주세요</option>
            {smartstoreCategories.map((c) => (
              <option value={c}>{c}</option>
            ))}
          </select>
          <p class="text-caption text-ink-500">
            경쟁사 보호 정책 적용을 위해 필요합니다.
          </p>

          {/* 기타 선택 시 노출되는 sub 필드 */}
          <div id="field-category-other-wrap" class="mt-sp-2 hidden flex-col gap-sp-2">
            <label for="field-category-other" class="text-body-sm font-medium text-ink-700">
              직접 입력
            </label>
            <input
              id="field-category-other"
              name="category_other"
              type="text"
              placeholder="예: 완구·취미"
              class="form-input"
            />
          </div>
        </div>
      </fieldset>

      {/* ---------- 선택 섹션 (접힘) ---------- */}
      <details class="mt-sp-7 rounded-md border border-ink-300/40 bg-paper-soft">
        <summary class="flex cursor-pointer items-center justify-between p-sp-4 text-body-sm font-semibold text-ink-900">
          <span>추가 정보 입력 (선택)</span>
          <svg
            class="details-chevron h-4 w-4 text-ink-500 transition-transform duration-base"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="m4 6 4 4 4-4"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </summary>

        <div class="flex flex-col gap-sp-6 border-t border-ink-300/40 p-sp-5">
          {/* 필드 4 — 월 광고비 */}
          <fieldset class="flex flex-col gap-sp-3">
            <legend class="text-body-sm font-semibold text-ink-900">
              현재 네이버광고 월 집행비
            </legend>
            {['아직 광고 안 돌림', '10만 원 미만', '10~30만 원', '30~50만 원', '50만 원 이상'].map(
              (o, i) => (
                <label class="inline-flex items-center gap-sp-3 text-body-sm text-ink-700">
                  <input
                    type="radio"
                    name="ad_budget"
                    value={o}
                    id={`field-budget-${i}`}
                    class="form-radio"
                  />
                  <span>{o}</span>
                </label>
              ),
            )}
            <p class="text-caption text-ink-500">
              수업 중 예시가 대표님 규모에 맞게 조정됩니다.
            </p>
          </fieldset>

          {/* 필드 5 — 운영 기간 */}
          <fieldset class="flex flex-col gap-sp-3">
            <legend class="text-body-sm font-semibold text-ink-900">
              스마트스토어 운영 기간
            </legend>
            {['6개월 미만', '6개월~1년', '1~2년', '2~3년', '3년 이상'].map((o, i) => (
              <label class="inline-flex items-center gap-sp-3 text-body-sm text-ink-700">
                <input
                  type="radio"
                  name="operation_period"
                  value={o}
                  id={`field-period-${i}`}
                  class="form-radio"
                />
                <span>{o}</span>
              </label>
            ))}
          </fieldset>

          {/* 필드 6 — 가장 궁금한 점 */}
          <div class="flex flex-col gap-sp-2">
            <label
              for="field-question"
              class="text-body-sm font-semibold text-ink-900"
            >
              가장 궁금하거나 고민되는 점 (선택)
            </label>
            <textarea
              id="field-question"
              name="question"
              rows="4"
              maxlength="500"
              placeholder="예: 지금 쇼핑검색 껐는데 다시 켜도 되는지 모르겠어요"
              class="form-input"></textarea>
            <p class="text-caption text-ink-500">
              사전 무료 강의 또는 첫 줌에서 답변드릴 수 있도록 준비합니다. (최대 500자)
            </p>
          </div>
        </div>
      </details>

      {/* ---------- 세금계산서 섹션 ---------- */}
      <div class="mt-sp-7 rounded-md border border-ink-300/40 bg-paper-soft p-sp-5">
        <label class="flex items-start gap-sp-3 text-body-sm font-semibold text-ink-900">
          <input
            id="field-invoice-toggle"
            name="invoice_requested"
            type="checkbox"
            value="yes"
            class="form-checkbox mt-[3px]"
          />
          <span>
            세금계산서 발행을 희망합니다 (법인·개인사업자)
            <span class="ml-sp-2 font-normal text-ink-500">
              · {brand.legalName} 명의 수기 발행
            </span>
          </span>
        </label>

        <div id="invoice-fields" class="mt-sp-5 hidden flex-col gap-sp-4">
          <div class="flex flex-col gap-sp-2">
            <label for="field-biz-number" class="text-body-sm font-semibold text-ink-900">
              사업자등록번호
              <span aria-hidden="true" class="ml-sp-1 text-danger">*</span>
            </label>
            <input
              id="field-biz-number"
              name="biz_number"
              type="text"
              inputmode="numeric"
              maxlength="12"
              placeholder="000-00-00000"
              class="form-input"
              data-format="biz-number"
            />
          </div>

          <div class="flex flex-col gap-sp-2">
            <label for="field-biz-name" class="text-body-sm font-semibold text-ink-900">
              법인명 또는 개인사업자 상호
              <span aria-hidden="true" class="ml-sp-1 text-danger">*</span>
            </label>
            <input
              id="field-biz-name"
              name="biz_name"
              type="text"
              placeholder="예: 주식회사 OOO"
              class="form-input"
            />
          </div>

          <div class="flex flex-col gap-sp-2">
            <label for="field-biz-email" class="text-body-sm font-semibold text-ink-900">
              세금계산서 수신 이메일
              <span aria-hidden="true" class="ml-sp-1 text-danger">*</span>
            </label>
            <input
              id="field-biz-email"
              name="biz_email"
              type="email"
              autocomplete="email"
              placeholder="예: accounting@company.co.kr"
              class="form-input"
            />
          </div>
        </div>
      </div>

      {/* ---------- 약관 동의 ---------- */}
      <fieldset class="mt-sp-7 flex flex-col gap-sp-4 border-t border-ink-300/40 pt-sp-6">
        <legend class="text-caption font-semibold tracking-caption text-gold-600">
          약관 동의 (필수 3개)
        </legend>

        <label class="flex items-start gap-sp-3 text-body-sm text-ink-700">
          <input
            type="checkbox"
            name="agree_account"
            required
            class="form-checkbox mt-[3px]"
            data-agreement
          />
          <span>
            {agreementLinks.accountPolicy}
            <span aria-hidden="true" class="ml-sp-1 text-danger">*</span>
          </span>
        </label>

        <label class="flex items-start gap-sp-3 text-body-sm text-ink-700">
          <input
            type="checkbox"
            name="agree_competitor"
            required
            class="form-checkbox mt-[3px]"
            data-agreement
          />
          <span>
            {agreementLinks.competitorPolicy}
            <span aria-hidden="true" class="ml-sp-1 text-danger">*</span>
          </span>
        </label>

        <label class="flex items-start gap-sp-3 text-body-sm text-ink-700">
          <input
            type="checkbox"
            name="agree_terms"
            required
            class="form-checkbox mt-[3px]"
            data-agreement
          />
          <span>
            <a
              href={routes.terms}
              target="_blank"
              rel="noopener"
              class="underline decoration-gold-500 underline-offset-4 hover:text-gold-600"
              >수강 약관</a
            >,
            <a
              href={routes.refund}
              target="_blank"
              rel="noopener"
              class="underline decoration-gold-500 underline-offset-4 hover:text-gold-600"
              >환불 정책</a
            >,
            <a
              href={routes.privacy}
              target="_blank"
              rel="noopener"
              class="underline decoration-gold-500 underline-offset-4 hover:text-gold-600"
              >개인정보처리방침</a
            >에 동의합니다
            <span aria-hidden="true" class="ml-sp-1 text-danger">*</span>
          </span>
        </label>
      </fieldset>

      {/* ---------- 제출 영역 ---------- */}
      <div class="mt-sp-7 flex flex-col gap-sp-3">
        <p class="text-body-sm text-ink-500">
          제출 후 12시간 이내에 카카오톡으로 진행 안내를 받으십니다.
        </p>
        <button
          id="apply-submit"
          type="submit"
          disabled
          aria-disabled="true"
          class="btn-base btn-primary btn-lg w-full shadow-gold disabled:cursor-not-allowed disabled:bg-ink-300 disabled:text-ink-500 disabled:shadow-none"
        >
          신청 제출하기 →
        </button>
        <p id="apply-submit-status" class="hidden text-center text-body-sm" role="status" aria-live="polite"></p>
      </div>
    </form>

    {/* ==================== SUCCESS PANEL ==================== */}
    <div
      id="apply-success"
      class="mx-auto mt-sp-8 hidden max-w-[640px] rounded-lg border-2 border-gold-500 bg-paper p-sp-7 text-center shadow-gold-ring"
      role="status"
      aria-live="polite"
    >
      <div
        aria-hidden="true"
        class="mx-auto inline-flex h-14 w-14 items-center justify-center rounded-full bg-gold-500/15 text-gold-600"
      >
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <path
            d="m7 14 5 5 10-12"
            stroke="currentColor"
            stroke-width="2.4"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </div>
      <h3 class="mt-sp-5 text-h3 font-bold text-ink-900">신청 접수 완료</h3>
      <p class="mt-sp-4 text-body text-ink-700">
        12시간 이내에 카카오톡으로 연락드립니다.<br />
        <span id="apply-success-contact" class="font-semibold text-gold-600"></span>
        으로 보내드릴게요.
      </p>
      <p class="mt-sp-3 text-body-sm text-ink-500">
        다음 기수 시작 예정일: {campaign.nextStartDate}
      </p>
      <div class="mt-sp-7 flex flex-col items-center justify-center gap-sp-3 sm:flex-row">
        <a href={routes.home} class="btn-base btn-secondary">← 메인으로 돌아가기</a>
        <a href={routes.curriculum} class="btn-base btn-secondary">커리큘럼 다시 보기</a>
      </div>
    </div>
  </div>
</section>

<style>
  /*
   * 폼 입력 공용 스타일 — tailwind로는 input::focus-within 상태 다루기가 불편해
   * 이 섹션에만 쓰이는 전용 유틸을 scoped <style> 로 분리.
   */
  .form-input {
    width: 100%;
    min-height: 44px;
    padding: 10px 14px;
    border: 1px solid var(--color-ink-300);
    border-radius: var(--radius-sm);
    background-color: #fff;
    font-size: var(--text-body-sm);
    color: var(--color-ink-900);
    transition:
      border-color var(--duration-fast) var(--easing-standard),
      box-shadow var(--duration-fast) var(--easing-standard);
  }
  .form-input::placeholder {
    color: var(--color-ink-500);
  }
  .form-input:focus {
    outline: none;
    border-color: var(--color-gold-500);
    box-shadow: 0 0 0 3px rgba(200, 155, 60, 0.2);
  }
  .form-input[aria-invalid='true'] {
    border-color: var(--color-danger);
  }
  textarea.form-input {
    min-height: 96px;
    resize: vertical;
  }
  /* details 마커 제거 + chevron 회전 */
  details > summary::-webkit-details-marker {
    display: none;
  }
  details > summary {
    list-style: none;
  }
  details[open] .details-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  /*
   * 05-pricing-apply.md §5 폼 상호작용
   *
   * 1. 카테고리 "기타" → 직접 입력 텍스트 박스 노출
   * 2. 세금계산서 체크 → 하위 3필드 노출 + required 토글
   * 3. 사업자번호 000-00-00000 자동 포맷
   * 4. 필수 3 + 약관 3 충족 시 제출 버튼 활성화
   * 5. 제출 시 fetch(Formspree) — 성공 화면 교체 / 실패 시 상태 메시지
   *
   * - Formspree endpoint 가 placeholder 상태면 fetch 는 실패하므로
   *   해당 경우 개발자 콘솔에 경고 + 에러 메시지 안내.
   */
  (() => {
    const form = document.getElementById('apply-form-element') as HTMLFormElement | null;
    if (!form) return;

    const submitBtn = document.getElementById('apply-submit') as HTMLButtonElement | null;
    const statusEl = document.getElementById('apply-submit-status') as HTMLParagraphElement | null;
    const successPanel = document.getElementById('apply-success');
    const successContact = document.getElementById('apply-success-contact');

    /* ---- 1) 카테고리 '기타' 동적 필드 ---- */
    const categorySelect = form.querySelector<HTMLSelectElement>('#field-category');
    const categoryOtherWrap = document.getElementById('field-category-other-wrap');
    categorySelect?.addEventListener('change', () => {
      const isOther = categorySelect.value.startsWith('기타');
      if (!categoryOtherWrap) return;
      categoryOtherWrap.classList.toggle('hidden', !isOther);
      categoryOtherWrap.classList.toggle('flex', isOther);
    });

    /* ---- 2) 세금계산서 섹션 토글 ---- */
    const invoiceToggle = form.querySelector<HTMLInputElement>('#field-invoice-toggle');
    const invoiceFields = document.getElementById('invoice-fields');
    const invoiceInputs = [
      form.querySelector<HTMLInputElement>('#field-biz-number'),
      form.querySelector<HTMLInputElement>('#field-biz-name'),
      form.querySelector<HTMLInputElement>('#field-biz-email'),
    ].filter((el): el is HTMLInputElement => !!el);

    const syncInvoice = () => {
      const open = !!invoiceToggle?.checked;
      invoiceFields?.classList.toggle('hidden', !open);
      invoiceFields?.classList.toggle('flex', open);
      invoiceInputs.forEach((inp) => {
        if (open) {
          inp.setAttribute('required', '');
        } else {
          inp.removeAttribute('required');
          inp.value = '';
        }
      });
    };
    invoiceToggle?.addEventListener('change', syncInvoice);

    /* ---- 3) 사업자번호 000-00-00000 자동 포맷 ---- */
    const bizNumber = form.querySelector<HTMLInputElement>('#field-biz-number');
    bizNumber?.addEventListener('input', () => {
      const digits = bizNumber.value.replace(/\D/g, '').slice(0, 10);
      let out = digits;
      if (digits.length > 3 && digits.length <= 5) {
        out = `${digits.slice(0, 3)}-${digits.slice(3)}`;
      } else if (digits.length > 5) {
        out = `${digits.slice(0, 3)}-${digits.slice(3, 5)}-${digits.slice(5)}`;
      }
      bizNumber.value = out;
    });

    /* ---- 4) 필수 + 약관 모두 충족 여부 감시 ---- */
    const requiredFields = form.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[data-required]');
    const agreements = form.querySelectorAll<HTMLInputElement>('[data-agreement]');

    const evaluate = () => {
      let ok = true;
      requiredFields.forEach((el) => {
        if (!el.value || (el instanceof HTMLInputElement && !el.checkValidity())) ok = false;
      });
      agreements.forEach((el) => {
        if (!el.checked) ok = false;
      });
      if (submitBtn) {
        submitBtn.disabled = !ok;
        submitBtn.setAttribute('aria-disabled', String(!ok));
      }
    };
    form.addEventListener('input', evaluate);
    form.addEventListener('change', evaluate);
    evaluate();

    /* ---- 5) 제출 ---- */
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || submitBtn.disabled) return;

      submitBtn.disabled = true;
      submitBtn.textContent = '제출 중...';
      statusEl?.classList.remove('hidden');
      if (statusEl) {
        statusEl.textContent = '';
        statusEl.classList.remove('text-danger');
        statusEl.classList.add('text-ink-500');
      }

      const endpoint = form.getAttribute('action') || '';
      const isPlaceholder = endpoint.includes('REPLACE_WITH_FORM_ID');

      try {
        if (isPlaceholder) {
          // 실제 Formspree ID 가 아직 주입되지 않은 상태.
          // 개발 환경에서 전체 플로우를 시연하기 위해 500ms 딜레이 후 성공 처리.
          console.warn('[apply] Formspree endpoint 가 placeholder 입니다. config/campaign.ts 의 formspree.endpoint 를 실제 값으로 교체해야 운영 가능합니다.');
          await new Promise((r) => setTimeout(r, 500));
        } else {
          const data = new FormData(form);
          const res = await fetch(endpoint, {
            method: 'POST',
            body: data,
            headers: { Accept: 'application/json' },
          });
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
        }

        // 성공 화면 교체
        const contact = (form.querySelector<HTMLInputElement>('#field-contact')?.value || '').trim();
        if (successContact) successContact.textContent = contact || '입력하신 연락처';
        form.classList.add('hidden');
        successPanel?.classList.remove('hidden');
        // 성공 패널로 부드럽게 스크롤
        successPanel?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } catch (err) {
        console.error(err);
        submitBtn.disabled = false;
        submitBtn.textContent = '신청 제출하기 →';
        if (statusEl) {
          statusEl.classList.remove('text-ink-500', 'hidden');
          statusEl.classList.add('text-danger');
          statusEl.textContent =
            '제출에 실패했습니다. 잠시 후 다시 시도하거나 ' +
            'cobaltblue8877@naver.com 으로 이메일을 보내주세요.';
        }
      }
    });
  })();
</script>
