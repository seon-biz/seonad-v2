---
/*
 * 03-curriculum.md §11 — 섹션 10 FAQ 10개 (3그룹)
 * 배경: paper-soft
 * 구현: native <details name="curriculum-faq"> 로 exclusive accordion (§14-7)
 *       (구 브라우저에서는 non-exclusive 동작 — 폴백 허용)
 */
import { routes } from '@config/campaign';

interface Faq {
  q: string;
  a: string;
}

const groups: { title: string; items: Faq[] }[] = [
  {
    title: '강의 구성',
    items: [
      {
        q: '총 몇 시간짜리 강의인가요?',
        a: 'VOD 7강 + 부록 240분과 줌 라이브 2회 각 120분, 합계 약 8시간 분량으로 구성됩니다. 여기에 강의 시작일 +3개월 애프터케어(단톡방 + 3개월 시점 점검 줌 1시간)이 더해집니다. 실제로 본인 계정을 켜고 캠페인을 발행하는 실습 시간까지 포함하면 대표님이 확보해야 할 총 학습 시간은 주당 2~3시간 수준입니다.',
      },
      {
        q: 'VOD는 언제까지 볼 수 있나요?',
        a: '해당 기수 수강생은 기수 내 무한 다시보기가 가능합니다. 네이버 UI 업데이트가 반영된 재촬영본은 별도 비용 없이 교체되어 제공됩니다. 복습이 필요한 강의는 언제든 되돌려 볼 수 있도록 설계되어 있습니다.',
      },
      {
        q: '줌 2회 일정은 어떻게 되나요?',
        a: '개강 시점에 6명 수강생 일정을 조율해 평일 저녁 또는 주말 오전 중 확정합니다. WEEK 3(계정 세팅 검수 + 첫 쇼핑검색광고 발행)과 WEEK 4(7일 성과 진단 + 파워링크 발행 + 30일 운영 플랜)이 각 120분씩 진행되며, 일정은 카카오톡 단톡방으로 최소 1주일 전에 공지됩니다.',
      },
      {
        q: '줌에 못 나가면 어떻게 되나요?',
        a: '실시간 참여가 원칙이지만 불가피한 사정이 있으면 줌 다시보기로 수업 내용을 모두 확인할 수 있습니다. 다만 본인 화면 공유·실시간 피드백을 받는 지점이 핵심이라, 가능한 일정에 맞춰 신청하시길 권장합니다. 두 회차 모두 불참한 경우 다음 기수 1회 무료 재수강 권리를 사용하실 수 있습니다.',
      },
      {
        q: '줌 다시보기는 기수 끝나면 사라지나요?',
        a: '줌 다시보기는 해당 기수의 6명 수강생만 접근할 수 있으며, 기수 내에서는 무한 재생됩니다. 개인정보(얼굴·스토어명·계정번호)는 마스킹·블러 처리되어 제공되고, 외부 공유·유출은 수강 약관으로 금지되어 있습니다.',
      },
    ],
  },
  {
    title: '내용·범위',
    items: [
      {
        q: '쇼핑검색광고, 파워링크, 브랜드검색광고 다 배우나요?',
        a: '네, 3가지 모두 다룹니다. 다만 스마트스토어 셀러에게는 쇼핑검색광고 메인, 파워링크·브랜드검색 서브 비중으로 시간과 우선순위를 배분했습니다. 쇼핑검색광고는 전략 설계 + 세팅 실습 + 최적화 사이클까지 3개 강의(85분)로 가장 깊게, 파워링크는 키워드 20개 추출 + 캠페인 발행 실습(40분), 브랜드검색광고는 필요 시점 판단 + 예산 분배 원칙(30분) 중심으로 구성됩니다.',
      },
      {
        q: 'GFA(AD voost)는 왜 안 다루나요?',
        a: 'GFA(이미지 디스플레이 광고)는 이번 강의 범위에 포함되지 않습니다. 스마트스토어 셀러의 초기 광고 집행에서는 구매 의도가 명확한 검색광고(쇼핑검색·파워링크)가 예산 효율이 높고, GFA는 브랜드 인지·리마케팅 목적이 명확해진 뒤에 확장하는 것이 현실적이라고 보기 때문입니다. GFA가 메인이 필요하신 분께는 이 강의가 맞지 않을 수 있습니다.',
      },
      {
        q: '스마트스토어가 아니면 못 듣나요?',
        a: '이 강의는 스마트스토어 셀러 전용으로 설계되어 있습니다. 쇼핑검색광고 연동, 전환추적 설치, 네이버페이 전환 기준 등 스마트스토어를 전제로 하는 내용이 상당 부분입니다. 자사몰·쿠팡·11번가 위주의 판매자라면 VOD는 이해하실 수 있어도 실습 단계에서 본인 스토어에 그대로 적용하기 어렵습니다.',
      },
    ],
  },
  {
    title: '실행·실습',
    items: [
      {
        q: '화면 따라하기 실습 3강은 진짜 초보도 되나요?',
        a: '네, 완전 초보 스마트스토어 셀러를 기준으로 설계됐습니다. 2강(계정 세팅 A to Z)은 비즈센터 가입부터, 4강(쇼핑검색광고 세팅 실습)은 첫 캠페인 발행까지, 6강(파워링크 키워드와 소재)은 키워드 20개 추출까지 — 세 강의 모두 실제 네이버 화면을 공유하며 클릭 하나하나를 따라가는 구성입니다. 따라가다 막히는 지점은 3주차 줌에서 화면 공유로 대표자가 직접 짚어드립니다.',
      },
      {
        q: '광고 계정이 없으면 어떻게 하나요?',
        a: '오히려 권장합니다. 2강(광고 계정 세팅 A to Z)의 첫 지시가 "네이버 비즈센터 가입부터"이기 때문에, 아직 계정이 없어야 깨끗한 상태에서 그대로 따라하기 가능합니다. 이미 계정이 있으시다면 전환추적·프리미엄 로그분석 설치 상태만 2강 기준으로 점검해주시면 됩니다.',
      },
    ],
  },
];

let globalIdx = 0;
---

<section
  id="curriculum-faq"
  class="bg-paper-soft text-ink-900"
  aria-labelledby="curriculum-faq-heading"
>
  <div class="container-max section-y">
    <header class="mx-auto max-w-[40ch] text-center">
      <h2
        id="curriculum-faq-heading"
        class="text-h2 font-bold"
      >
        커리큘럼 관련 10가지.
      </h2>
      <p class="mt-sp-3 text-body text-ink-500">
        강의 구성·내용·실습에 대해 가장 많이 받은 질문입니다.
      </p>
    </header>

    <div class="mx-auto mt-sp-7 max-w-[820px] space-y-sp-6">
      {
        groups.map((group) => (
          <div>
            <h3 class="text-caption font-semibold uppercase tracking-eyebrow text-gold-600">
              [{group.title}]
            </h3>
            <ul class="mt-sp-3 divide-y divide-ink-300/40 overflow-hidden rounded-lg border border-ink-300/40 bg-paper">
              {group.items.map((item) => {
                globalIdx += 1;
                return (
                  <li>
                    <details name="curriculum-faq" class="group">
                      <summary class="flex cursor-pointer select-none items-start justify-between gap-sp-4 px-sp-5 py-sp-5 text-left">
                        <span class="text-h4 font-semibold text-ink-900">
                          <span class="mr-sp-2 text-gold-600">Q{globalIdx}.</span>
                          {item.q}
                        </span>
                        <span
                          aria-hidden="true"
                          class="mt-sp-1 shrink-0 text-gold-600 transition-transform duration-base group-open:rotate-45"
                        >
                          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                            <line x1="9" y1="3" x2="9" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                            <line x1="3" y1="9" x2="15" y2="9" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                          </svg>
                        </span>
                      </summary>
                      <div class="border-t border-ink-300/30 bg-paper-soft px-sp-5 py-sp-5">
                        <p class="text-body text-ink-700">
                          <span class="mr-sp-2 font-semibold text-gold-600">
                            A.
                          </span>
                          {item.a}
                        </p>
                      </div>
                    </details>
                  </li>
                );
              })}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-sp-6 flex justify-center">
      <a href={routes.faq} class="btn-base btn-secondary-light">
        전체 FAQ 보기 →
      </a>
    </div>
  </div>
</section>
