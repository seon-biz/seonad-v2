---
/*
 * 03-curriculum.md §10 — 섹션 9 이런 분께 권합니다 / 맞지 않습니다
 * 배경: paper
 * 모바일 순서: "맞습니다" 먼저 → "맞지 않습니다" 나중 (§14-6)
 */
import { routes } from '@config/campaign';

const fits = [
  '스마트스토어 오픈 3개월~2년차, 상품 10~50개',
  '광고를 한 번도 안 켜봤거나 한두 번 켜보고 멈춘 분',
  '월 광고비 30만 원 이상 집행 가능한 분',
  '본인 계정을 동기 5명에게 공개해도 괜찮은 분',
  '4주간 VOD 예습 + 줌 2회에 시간을 낼 수 있는 분',
  '대행사에 맡기더라도 **먼저 내 손으로** 해보고 싶은 분',
];

const unfits = [
  '스마트스토어가 아닌 자사몰·쿠팡·11번가 위주의 판매자',
  '월 광고비 30만 원 미만 (광고 테스트 데이터 확보 자체가 어려움)',
  'GFA(이미지 디스플레이 광고)를 메인으로 배우고 싶은 분',
  '대행사에 맡기는 것만 검토 중이고 직접 운영 의향은 없는 분',
  '익명으로 참여해 계정을 공개하지 않고 싶은 분',
];
---

<section
  id="curriculum-self-check"
  class="bg-paper text-ink-900"
  aria-labelledby="self-check-heading"
>
  <div class="container-max section-y">
    <header class="mx-auto max-w-[40ch] text-center">
      <h2
        id="self-check-heading"
        class="text-h2 font-bold"
      >
        이런 분께 맞고,<br />
        이런 분께는 맞지 않습니다.
      </h2>
    </header>

    <div class="mt-sp-7 grid grid-cols-1 gap-sp-5 md:grid-cols-2">
      {/* ✓ 맞습니다 — 모바일 먼저 */}
      <article class="order-1 rounded-lg border-2 border-gold-500 bg-paper-soft p-sp-5 md:p-sp-6">
        <div class="flex items-center gap-sp-3">
          <span
            aria-hidden="true"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-gold-500 text-navy-950"
          >
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M3 9 L7.5 13.5 L15 5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
          <h3 class="text-h3 font-semibold text-ink-900">이런 분께 맞습니다</h3>
        </div>
        <ul class="mt-sp-5 flex flex-col gap-sp-3 text-body text-ink-700">
          {
            fits.map((f) => (
              <li class="flex items-start gap-sp-3">
                <span aria-hidden="true" class="mt-[3px] shrink-0 text-gold-600">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8 L7 12 L13 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
                <span set:html={f.replace(/\*\*(.+?)\*\*/g, '<strong class="text-ink-900">$1</strong>')} />
              </li>
            ))
          }
        </ul>
      </article>

      {/* ✗ 맞지 않습니다 — 모바일 나중 */}
      <article class="order-2 rounded-lg border border-ink-300/60 bg-paper p-sp-5 md:p-sp-6">
        <div class="flex items-center gap-sp-3">
          <span
            aria-hidden="true"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-ink-300 text-ink-500"
          >
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <line x1="4" y1="4" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              <line x1="12" y1="4" x2="4" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </span>
          <h3 class="text-h3 font-semibold text-ink-500">이런 분께는 맞지 않습니다</h3>
        </div>
        <ul class="mt-sp-5 flex flex-col gap-sp-3 text-body text-ink-500">
          {
            unfits.map((f) => (
              <li class="flex items-start gap-sp-3">
                <span aria-hidden="true" class="mt-[3px] shrink-0 text-ink-300">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <line x1="3" y1="3" x2="11" y2="11" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    <line x1="11" y1="3" x2="3" y2="11" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                  </svg>
                </span>
                <span>{f}</span>
              </li>
            ))
          }
        </ul>
      </article>
    </div>

    <p class="mx-auto mt-sp-7 max-w-[50ch] text-center text-body text-ink-500">
      애매하시다면
      <a
        href={routes.free}
        class="font-semibold text-gold-600 underline decoration-gold-500 underline-offset-4 hover:text-gold-500"
      >
        사전 무료 강의 1시간
      </a>
      을 먼저 들어보시고 판단하셔도 됩니다.
    </p>
  </div>
</section>
