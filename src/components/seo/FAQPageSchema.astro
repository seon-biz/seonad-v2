---
/*
 * FAQPageSchema — 06-faq.md §0-2
 *
 * 43개 질문 전량을 FAQPage JSON-LD 로 구조화한다.
 * - answer.text 는 normalizeAnswerForSchema 로 줄바꿈·연속공백 압축한 순수 텍스트.
 * - /src/data/faq.ts 의 FAQ_ITEMS 를 직접 참조해 화면과 Schema 단일 소스 동기화.
 * - 부분 반영 금지: 전부 포함해야 Rich Snippet + AI 인용 조건을 충족한다.
 */
import JsonLd from './JsonLd.astro';
import { FAQ_ITEMS, normalizeAnswerForSchema } from '@data/faq';

interface Props {
  id?: string;
}
const { id = 'schema-faqpage' } = Astro.props;

const data = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: normalizeAnswerForSchema(item.answer),
    },
  })),
};
---

<JsonLd data={data} id={id} />
