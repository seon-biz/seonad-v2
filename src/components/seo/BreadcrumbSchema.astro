---
import JsonLd from './JsonLd.astro';
import { brand } from '@config/campaign';

interface Item {
  name: string;
  url: string;
}
interface Props {
  items: Item[];
  id?: string;
}
const { items, id = 'schema-breadcrumb' } = Astro.props;

const data = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    name: item.name,
    item: item.url.startsWith('http') ? item.url : `${brand.url}${item.url}`,
  })),
};
---

<JsonLd data={data} id={id} />
