---
/*
 * PersonSchema — 04-instructor.md §0-2
 *
 * 세온애드 코치의 Person + Organization(worksFor/affiliation) 결합 스키마.
 * 실명·얼굴 비공개 원칙에 따라 name 은 "세온애드 코치" 로 고정한다(§12-10).
 */
import JsonLd from './JsonLd.astro';
import { brand } from '@config/campaign';

interface Props {
  id?: string;
}
const { id = 'schema-person-instructor' } = Astro.props;

const data = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: '세온애드 코치',
  jobTitle: '스마트스토어 네이버광고 코치',
  worksFor: {
    '@type': 'Organization',
    name: brand.legalName,
    sameAs: brand.url,
  },
  affiliation: {
    '@type': 'Organization',
    name: '세온비즈',
    url: 'https://seonbiz.co',
  },
  knowsAbout: [
    '네이버 쇼핑검색광고',
    '네이버 파워링크',
    '네이버 브랜드검색광고',
    '스마트스토어 운영',
    '이커머스 마케팅',
  ],
  description:
    '2019년부터 쇼핑몰·스마트스토어 대표를 1:1 코칭해온 온라인 마케팅 코치. 세온비즈 대표로서 30여 개 업체를 직접 지도했다.',
};
---

<JsonLd data={data} id={id} />
