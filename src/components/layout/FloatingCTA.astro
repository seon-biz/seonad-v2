---
/*
 * 모바일 하단 플로팅 CTA (02-main-page.md §1-2)
 *
 * 두 레이어 가시성 모델:
 *  A) 히어로 통과 여부 — display: none/flex (레이아웃 자체 존재/부재)
 *     기본 노출 지점: #hero-sentinel 이 뷰포트를 벗어났을 때.
 *     sentinel 이 없는 페이지에서는 scrollY > 480px 임계값으로 폴백.
 *
 *  B) 푸터 겹침 여부 — opacity + pointer-events (transition-opacity 300ms)
 *     <footer> 가 threshold 0.1 로 뷰포트에 진입하면 opacity-0 으로 부드럽게
 *     페이드아웃 + pointer-events-none 으로 클릭 영역 제거.
 *     푸터에 이미 "사전 무료 강의" · "수강 신청" 풀바 CTA 역할이 충분하므로
 *     플로팅이 겹쳐서 골드 블록 두 개가 쌓이는 상황을 방지한다.
 *
 * 문구/링크 교체: #pricing-trigger 가 뷰포트에 들어오면 "수강 신청하기 →" + /apply,
 * 벗어나면 "사전 무료 강의 신청 →" + /free 로 원복.
 *
 * lg(1024) 이상에서는 렌더되지 않음 (`lg:hidden`) — 데스크톱 헤더 CTA 로 대체.
 * prefers-reduced-motion: global.css 의 전역 감축 규칙으로 transition 이 사실상
 * 즉시 완료됨.
 *
 * 페이지 측 요구사항(선택):
 *  - 히어로 섹션 하단에 <span id="hero-sentinel" class="sr-only" /> 배치
 *  - 가격 섹션 시작부에 <span id="pricing-trigger" class="sr-only" /> 배치
 */

import { routes } from '@config/campaign';
---

<div
  id="floating-cta"
  class="fixed inset-x-0 bottom-0 z-sticky-cta hidden px-gutter-mobile pb-[max(12px,env(safe-area-inset-bottom))] transition-opacity duration-300 ease-out lg:hidden"
  data-visible="false"
  data-mode="free"
  data-footer-overlap="false"
>
  <a
    id="floating-cta-link"
    href={routes.free}
    class="btn-base btn-primary btn-lg w-full shadow-gold"
  >
    <span id="floating-cta-label">사전 무료 강의 신청 →</span>
  </a>
</div>

<script>
  const wrap = document.getElementById('floating-cta');
  const link = document.getElementById('floating-cta-link') as HTMLAnchorElement | null;
  const label = document.getElementById('floating-cta-label');
  if (wrap && link && label) {
    const FREE = { href: '/free', text: '사전 무료 강의 신청 →' };
    const APPLY = { href: '/apply', text: '수강 신청하기 →' };

    /* Layer A — 히어로 통과 후 레이아웃 자체 노출(display 토글) */
    const setVisible = (visible: boolean) => {
      wrap.dataset.visible = String(visible);
      wrap.classList.toggle('hidden', !visible);
      wrap.classList.toggle('flex', visible);
    };

    const setMode = (mode: 'free' | 'apply') => {
      wrap.dataset.mode = mode;
      const target = mode === 'apply' ? APPLY : FREE;
      link.href = target.href;
      label.textContent = target.text;
    };

    /* Layer B — 푸터 진입 시 부드러운 opacity 페이드 + 클릭 비활성 */
    const setFooterOverlap = (overlap: boolean) => {
      wrap.dataset.footerOverlap = String(overlap);
      wrap.classList.toggle('opacity-0', overlap);
      wrap.classList.toggle('pointer-events-none', overlap);
      if (overlap) {
        wrap.setAttribute('aria-hidden', 'true');
      } else {
        wrap.removeAttribute('aria-hidden');
      }
    };

    // 1) 히어로 sentinel 관찰 → 통과 시 노출
    const hero = document.getElementById('hero-sentinel');
    if (hero) {
      const io = new IntersectionObserver(
        ([entry]) => setVisible(!entry.isIntersecting),
        { rootMargin: '0px 0px -40% 0px', threshold: 0 },
      );
      io.observe(hero);
    } else {
      // 폴백: scrollY 임계값
      const onScroll = () => setVisible(window.scrollY > 480);
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    // 2) 가격 섹션 트리거 관찰 → 문구 교체
    const pricing = document.getElementById('pricing-trigger');
    if (pricing) {
      const io2 = new IntersectionObserver(
        ([entry]) => setMode(entry.isIntersecting ? 'apply' : 'free'),
        { rootMargin: '0px 0px -40% 0px', threshold: 0 },
      );
      io2.observe(pricing);
    }

    // 3) 푸터 관찰 → 진입 시 페이드아웃 / 벗어나면 페이드인
    const footer = document.querySelector('footer');
    if (footer) {
      const io3 = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => setFooterOverlap(entry.isIntersecting));
        },
        { threshold: 0.1 },
      );
      io3.observe(footer);
    }
  }
</script>

<style>
  #floating-cta[data-visible='true'] {
    display: flex;
  }
</style>
