---
import Logo from './Logo.astro';
import { campaign, routes, brand } from '@config/campaign';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const navItems = [
  { label: '커리큘럼', href: routes.curriculum },
  { label: '강사', href: routes.instructor },
  { label: '가격', href: routes.apply },
  { label: 'FAQ', href: routes.faq },
  { label: '블로그', href: routes.blog },
];

const isActive = (href: string) => {
  const clean = href.replace(/\/$/, '') || '/';
  if (clean === '/') return currentPath === '/';
  return currentPath === clean || currentPath.startsWith(clean + '/');
};
---

<header
  id="site-header"
  class="sticky top-0 z-header bg-navy-950/95 backdrop-blur transition-colors duration-base ease-standard"
  data-scrolled="false"
>
  <div class="container-max flex h-14 items-center justify-between gap-sp-4 lg:h-[72px]">
    <!-- 좌측: 로고 + 태그라인(md 이상) + 모집 배지(옵션) -->
    <div class="flex items-center gap-sp-4">
      <Logo variant="light" />
      <span class="hidden text-caption tracking-caption text-on-dark-soft md:inline">
        {brand.tagline}
      </span>
      {campaign.currentCohort.isRecruiting && (
        <span class="hidden pill pill-outline-gold lg:inline-flex">
          현재 {campaign.currentCohort.number}기 {campaign.currentCohort.currentCount}/{campaign.currentCohort.maxCount}명
        </span>
      )}
    </div>

    <!-- 중앙: 데스크톱 메뉴 -->
    <nav class="hidden lg:block" aria-label="주요 메뉴">
      <ul class="flex items-center gap-sp-6">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'inline-flex h-9 items-center text-body-sm font-medium text-on-dark transition-colors duration-fast ease-standard hover:text-gold-400',
                isActive(item.href) && 'relative text-gold-400',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
              {isActive(item.href) && (
                <span
                  aria-hidden="true"
                  class="absolute inset-x-0 -bottom-1 h-[2px] bg-gold-500"
                ></span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- 우측: 데스크톱 Primary CTA + 모바일 축약 CTA + 햄버거 -->
    <div class="flex items-center gap-sp-2">
      <a
        href={routes.free}
        class="btn-base btn-primary hidden lg:inline-flex"
      >
        사전 무료 강의 신청
      </a>
      <a
        href={routes.free}
        class="btn-base btn-primary lg:hidden"
        style="min-height:40px;padding:10px 14px;font-size:var(--text-body-sm);"
      >
        무료 강의
      </a>
      <button
        id="menu-open"
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-md text-on-dark transition-colors duration-fast ease-standard hover:bg-navy-800 lg:hidden"
        aria-label="메뉴 열기"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- 모바일 오버레이 메뉴 -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-overlay hidden flex-col bg-navy-950 lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="모바일 메뉴"
>
  <div class="container-max flex h-14 items-center justify-between">
    <Logo variant="light" />
    <button
      id="menu-close"
      type="button"
      class="inline-flex h-11 w-11 items-center justify-center rounded-md text-on-dark transition-colors duration-fast ease-standard hover:bg-navy-800"
      aria-label="메뉴 닫기"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M6 6l12 12M6 18L18 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <div class="container-max flex flex-1 flex-col justify-between py-sp-6">
    <nav aria-label="모바일 주요 메뉴">
      <ul class="flex flex-col gap-sp-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'block rounded-md px-sp-4 py-sp-4 text-h3 font-semibold text-on-dark transition-colors duration-fast ease-standard hover:bg-navy-900',
                isActive(item.href) && 'text-gold-400',
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="mt-sp-6 flex flex-col gap-sp-3">
      <a href={routes.free} class="btn-base btn-primary btn-lg w-full">
        사전 무료 강의 신청 →
      </a>
      <a href={routes.apply} class="btn-base btn-secondary btn-lg w-full">
        수강 신청하기 →
      </a>
      {campaign.currentCohort.isRecruiting && (
        <p class="mt-sp-2 text-center text-body-sm text-gold-300">
          {campaign.getRecruitmentLine()}
        </p>
      )}
    </div>
  </div>
</div>

<script>
  // 스크롤 임계값 넘으면 헤더에 골드 하단 라인 + 더 진한 배경
  const header = document.getElementById('site-header');
  const onScroll = () => {
    if (!header) return;
    const scrolled = window.scrollY > 8;
    header.dataset.scrolled = String(scrolled);
    header.classList.toggle('is-scrolled', scrolled);
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // 모바일 메뉴 열고 닫기 + ESC + 바디 스크롤 잠금 + 포커스 트랩(간이)
  const openBtn = document.getElementById('menu-open');
  const closeBtn = document.getElementById('menu-close');
  const menu = document.getElementById('mobile-menu');

  const setMenu = (open: boolean) => {
    if (!menu || !openBtn) return;
    menu.classList.toggle('hidden', !open);
    menu.classList.toggle('flex', open);
    openBtn.setAttribute('aria-expanded', String(open));
    document.documentElement.style.overflow = open ? 'hidden' : '';
    if (open) {
      const firstLink = menu.querySelector('a, button') as HTMLElement | null;
      firstLink?.focus();
    } else {
      openBtn.focus();
    }
  };

  openBtn?.addEventListener('click', () => setMenu(true));
  closeBtn?.addEventListener('click', () => setMenu(false));

  // 메뉴 내 링크 클릭 시 자동 닫기
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => setMenu(false)),
  );

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu && !menu.classList.contains('hidden')) {
      setMenu(false);
    }
  });

  // lg 브레이크포인트 넘어가면 자동 닫기 (리사이즈 대응)
  const mq = window.matchMedia('(min-width: 1024px)');
  mq.addEventListener('change', (e) => {
    if (e.matches) setMenu(false);
  });
</script>

<style>
  /* 스크롤 후 헤더 하단 골드 라인 + 배경 한 단계 진하게 */
  #site-header.is-scrolled {
    background-color: var(--color-navy-900);
    box-shadow: inset 0 -1px 0 var(--color-gold-500);
  }
</style>
