---
/*
 * 법적 문서 본문 블록 렌더러. LegalBlock 타입 유니언을 시각적으로 일관되게 표시.
 *
 * 디자인 원칙(09-legal.md §0-2, §4-4):
 *   - 본문 폰트는 Pretendard(Tailwind sans), text-body, line-height 1.8
 *   - 조문 본문 색상은 --color-ink-900 (가독성 + 과장 없는 톤)
 *   - 리스트·표는 구조만 구분 (강한 색상 강조 금지)
 *   - "가. 나. 다." 소제목은 subheading 타입으로 약간 굵게
 */
import type { LegalBlock } from '@data/legal/types';

interface Props {
  block: LegalBlock;
}
const { block } = Astro.props as Props;
---

{block.type === 'p' && (
  <p class="text-body leading-[1.8] text-ink-900">{block.text}</p>
)}

{block.type === 'subheading' && (
  <p class="mt-sp-4 text-body font-semibold text-ink-900">{block.text}</p>
)}

{block.type === 'ol' && (
  <ol class="list-decimal space-y-sp-2 pl-sp-6 text-body leading-[1.8] text-ink-900 marker:text-ink-500 marker:font-semibold">
    {block.items.map((item) => <li>{item}</li>)}
  </ol>
)}

{block.type === 'ul' && (
  <ul class="list-disc space-y-sp-2 pl-sp-6 text-body leading-[1.8] text-ink-900 marker:text-ink-500">
    {block.items.map((item) => <li>{item}</li>)}
  </ul>
)}

{block.type === 'ol-latin' && (
  <ol class="list-[korean-syllable] space-y-sp-2 pl-sp-6 text-body leading-[1.8] text-ink-900 marker:text-ink-500 marker:font-semibold">
    {block.items.map((item) => <li>{item}</li>)}
  </ol>
)}

{block.type === 'table' && (
  <div class="overflow-x-auto">
    <table class="legal-table w-full border-collapse text-body-sm text-ink-900">
      {block.caption && <caption class="caption-top pb-sp-2 text-caption text-ink-500">{block.caption}</caption>}
      <thead>
        <tr>
          {block.headers.map((h) => (
            <th
              scope="col"
              class="border border-ink-300/60 bg-paper px-sp-4 py-sp-3 text-left text-body-sm font-semibold text-ink-900"
            >
              {h}
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {block.rows.map((row) => (
          <tr>
            {row.map((cell) => (
              <td class="border border-ink-300/60 px-sp-4 py-sp-3 align-top leading-[1.7]">
                {cell}
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}
