---
/*
 * 플레이스홀더 페이지 공통 — 1기 런칭 전 MD 명세가 아직 없는 경로용.
 * 404 방지 + 헤더/푸터는 그대로 유지됨 (BaseLayout 에서 렌더).
 */
import { routes } from '@config/campaign';

interface Props {
  pageTitle: string;
  description?: string;
  expectedStage?: string; // "05-pricing-apply.md" 같은 실제 명세 번호 안내
}
const {
  pageTitle,
  description = '해당 페이지는 1기 런칭 전 준비 중입니다. 곧 공개될 예정입니다.',
  expectedStage,
} = Astro.props;
---

<main id="main-content" tabindex="-1" class="bg-navy-950">
  <section class="section-y">
    <div class="container-narrow text-center">
      <p class="eyebrow">SEONAD · 준비 중</p>
      <h1 class="mt-sp-5 text-h1 font-sans text-white">
        {pageTitle}
      </h1>
      <p class="mx-auto mt-sp-5 max-w-[560px] text-lead text-on-dark-soft">
        {description}
      </p>
      {expectedStage && (
        <p class="mt-sp-3 text-body-sm text-on-dark-soft">
          (명세 파일: <code class="text-gold-300">{expectedStage}</code>)
        </p>
      )}

      <div class="mt-sp-7 flex flex-col items-center justify-center gap-sp-3 sm:flex-row">
        <a href={routes.free} class="btn-base btn-primary btn-lg">
          사전 무료 강의 신청 →
        </a>
        <a href={routes.home} class="btn-base btn-secondary btn-lg">
          ← 메인으로 돌아가기
        </a>
      </div>
    </div>
  </section>
</main>
